  "features.progress.desc": "\u05d2\u05e8\u05e4\u05d9\u05dd, \u05e8\u05e6\u05e4\u05d9\u05dd \u05d5\u05e6\u05d9\u05d5\u05e0\u05d9\u05dd &mdash; \u05e8\u05d0\u05d5 \u05db\u05de\u05d4 \u05d4\u05ea\u05e7\u05d3\u05de\u05ea\u05dd \u05d5\u05de\u05d4 \u05e2\u05d5\u05d3 \u05d3\u05d5\u05e8\u05e9 \u05e2\u05d1\u05d5\u05d3\u05d4.",
  "features.pronunciation.tag": "\u05de\u05d0\u05de\u05df \u05de\u05d1\u05d8\u05d0",
  "features.pronunciation.title": "\u05d0\u05d9\u05de\u05d5\u05df \u05d4\u05d2\u05d9\u05d9\u05d4",
  "features.pronunciation.desc": "\u05ea\u05e8\u05d2\u05d9\u05dc\u05d9\u05dd \u05d9\u05d9\u05e2\u05d5\u05d3\u05d9\u05d9\u05dd \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d4\u05de\u05d1\u05d8\u05d0, \u05d1\u05ea\u05d5\u05e1\u05e4\u05ea \u05de\u05e9\u05d5\u05d1 \u05d0\u05d7\u05e8\u05d9 \u05db\u05dc \u05e9\u05d9\u05d7\u05d4.",
  "howItWorks.eyebrow": "\u05d0\u05d9\u05da \u05d6\u05d4 \u05e2\u05d5\u05d1\u05d3",
  "howItWorks.title": "\u05de\u05d0\u05e4\u05e1 \u05d5\u05e2\u05d3 \u05d3\u05d9\u05d1\u05d5\u05e8 \u05d1-4 \u05e6\u05e2\u05d3\u05d9\u05dd \u05e4\u05e9\u05d5\u05d8\u05d9\u05dd",
  "howItWorks.subtitle": "\u05d1\u05dc\u05d9 \u05d4\u05d2\u05d3\u05e8\u05d5\u05ea \u05de\u05e1\u05d5\u05d1\u05db\u05d5\u05ea. \u05d1\u05dc\u05d9 \u05e1\u05e4\u05e8\u05d9 \u05dc\u05d9\u05de\u05d5\u05d3. \u05e4\u05e9\u05d5\u05d8 \u05ea\u05ea\u05d7\u05d9\u05dc\u05d5 \u05dc\u05d3\u05d1\u05e8.",
  "howItWorks.step1.num": "01",
  "howItWorks.step1.title": "\u05d1\u05d7\u05e8\u05d5 \u05e9\u05e4\u05d4",
  "howItWorks.step1.desc": "\u05d1\u05d7\u05e8\u05d5 \u05de-10 \u05e9\u05e4\u05d5\u05ea &mdash; \u05e1\u05e4\u05e8\u05d3\u05d9\u05ea, \u05d0\u05e0\u05d2\u05dc\u05d9\u05ea, \u05d2\u05e8\u05de\u05e0\u05d9\u05ea, \u05e6\u05e8\u05e4\u05ea\u05d9\u05ea, \u05d0\u05d9\u05d8\u05dc\u05e7\u05d9\u05ea \u05d5\u05e2\u05d5\u05d3. \u05d4\u05d2\u05d3\u05d9\u05e8\u05d5 \u05d0\u05ea \u05e8\u05de\u05ea \u05d4-CEFR \u05de-A1 (\u05de\u05ea\u05d7\u05d9\u05dc) \u05e2\u05d3 C2 (\u05e9\u05e4\u05ea \u05d0\u05dd).",
  "howItWorks.step2.num": "02",
  "howItWorks.step2.title": "\u05d1\u05d7\u05e8\u05d5 \u05ea\u05e8\u05d7\u05d9\u05e9",
  "howItWorks.step2.desc": "\u05d1\u05d1\u05d9\u05ea \u05e7\u05e4\u05d4, \u05e8\u05d0\u05d9\u05d5\u05df \u05e2\u05d1\u05d5\u05d3\u05d4, \u05d1\u05e7\u05e9\u05ea \u05d4\u05db\u05d5\u05d5\u05e0\u05d5\u05ea &mdash; \u05d0\u05d5 \u05e4\u05e9\u05d5\u05d8 \u05d3\u05d1\u05e8\u05d5 \u05d7\u05d5\u05e4\u05e9\u05d9. \u05d4\u05de\u05d5\u05e8\u05d4 \u05de\u05ea\u05d0\u05d9\u05dd \u05dc\u05db\u05dc \u05e0\u05d5\u05e9\u05d0.",
  "howItWorks.step3.num": "03",
  "howItWorks.step3.title": "\u05d3\u05d1\u05e8\u05d5 \u05d1\u05d0\u05d5\u05e4\u05df \u05d8\u05d1\u05e2\u05d9",
  "howItWorks.step3.desc": "\u05d3\u05d1\u05e8\u05d5 \u05e2\u05dd \u05d4\u05de\u05d5\u05e8\u05d4 \u05d4-AI \u05e9\u05dc\u05db\u05dd \u05d1\u05e7\u05d5\u05dc \u05d0\u05d5 \u05d1\u05d8\u05e7\u05e1\u05d8. \u05e7\u05d1\u05dc\u05d5 \u05d4\u05e6\u05e2\u05d5\u05ea \u05dc\u05ea\u05e9\u05d5\u05d1\u05d5\u05ea \u05db\u05e9\u05e0\u05ea\u05e7\u05e2\u05d9\u05dd. \u05d1\u05dc\u05d9 \u05e9\u05d9\u05e4\u05d5\u05d8, \u05e8\u05e7 \u05ea\u05e8\u05d2\u05d5\u05dc.",
  "howItWorks.step4.num": "04",
  "howItWorks.step4.title": "\u05e1\u05e7\u05e8\u05d5 \u05d5\u05d4\u05e9\u05ea\u05e4\u05e8\u05d5",
  "howItWorks.step4.desc": "\u05e8\u05d0\u05d5 \u05db\u05dc \u05e9\u05d2\u05d9\u05d0\u05d4 \u05de\u05e1\u05d5\u05de\u05e0\u05ea \u05d1\u05e6\u05d1\u05e2 \u05e2\u05dd \u05ea\u05d9\u05e7\u05d5\u05e0\u05d9\u05dd. \u05e9\u05de\u05e8\u05d5 \u05de\u05d9\u05dc\u05d9\u05dd \u05d7\u05d3\u05e9\u05d5\u05ea \u05d1\u05db\u05e8\u05d8\u05d9\u05e1\u05d9\u05d5\u05ea. \u05e2\u05e7\u05d1\u05d5 \u05d0\u05d7\u05e8 \u05d4\u05d4\u05ea\u05e7\u05d3\u05de\u05d5\u05ea \u05d1\u05dc\u05d5\u05d7 \u05d4\u05d1\u05e7\u05e8\u05d4.",
