  "features.scenarios.desc": "\u05d1\u05d9\u05ea \u05e7\u05e4\u05d4, \u05e8\u05d0\u05d9\u05d5\u05df \u05e2\u05d1\u05d5\u05d3\u05d4, \u05e9\u05d3\u05d4 \u05ea\u05e2\u05d5\u05e4\u05d4, \u05de\u05dc\u05d5\u05df &mdash; \u05d0\u05d5 \u05e4\u05e9\u05d5\u05d8 \u05e9\u05d5\u05d7\u05d7\u05d5 \u05d7\u05d5\u05e4\u05e9\u05d9. \u05d4\u05de\u05d5\u05e8\u05d4 \u05de\u05ea\u05d0\u05d9\u05dd \u05dc\u05db\u05dc \u05e0\u05d5\u05e9\u05d0.",
  "features.level.tag": "\u05de\u05d5\u05ea\u05d0\u05dd \u05d0\u05d9\u05e9\u05d9\u05ea",
