  "features.vocab.desc": "\u05de\u05d9\u05dc\u05d9\u05dd \u05d7\u05d3\u05e9\u05d5\u05ea \u05e0\u05e9\u05de\u05e8\u05d5\u05ea \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea. \u05db\u05e8\u05d8\u05d9\u05e1\u05d9\u05d5\u05ea \u05d7\u05db\u05de\u05d5\u05ea \u05de\u05d7\u05d6\u05d9\u05e8\u05d5\u05ea \u05d0\u05d5\u05ea\u05df \u05d1\u05d6\u05de\u05df \u05d4\u05de\u05d5\u05e9\u05dc\u05dd.",
