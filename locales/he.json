  "pricing.premium.f7": "\u05de\u05d5\u05d3\u05dc\u05d9 AI \u05de\u05ea\u05e7\u05d3\u05de\u05d9\u05dd",
  "pricing.premium.cta": "\u05d4\u05ea\u05d7\u05d9\u05dc\u05d5 \u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05d7\u05d9\u05e0\u05dd",
  "social.quote1": "\u05e0\u05d9\u05e1\u05d9\u05ea\u05d9 Duolingo, Babbel \u05d5\u05d0\u05d7\u05e8\u05d9\u05dd &mdash; Fonvo \u05d4\u05d9\u05d0 \u05d4\u05d0\u05e4\u05dc\u05d9\u05e7\u05e6\u05d9\u05d4 \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05e9\u05d1\u05d4 \u05d0\u05e0\u05d9 \u05d1\u05d0\u05de\u05ea \u05de\u05d3\u05d1\u05e8. \u05d0\u05d7\u05e8\u05d9 \u05e9\u05d1\u05d5\u05e2\u05d9\u05d9\u05dd \u05e0\u05d9\u05d4\u05dc\u05ea\u05d9 \u05e9\u05d9\u05d7\u05d4 \u05d0\u05de\u05d9\u05ea\u05d9\u05ea \u05d1\u05e1\u05e4\u05e8\u05d3\u05d9\u05ea.",
  "social.author1": "Marta K.",
  "social.role1": "\u05dc\u05d5\u05de\u05d3\u05ea \u05e1\u05e4\u05e8\u05d3\u05d9\u05ea",
  "social.quote2": "\u05d4\u05de\u05d5\u05e8\u05d9\u05dd \u05de\u05e8\u05d2\u05d9\u05e9\u05d9\u05dd \u05d0\u05de\u05d9\u05ea\u05d9\u05d9\u05dd \u05dc\u05d4\u05e4\u05dc\u05d9\u05d0. Luna \u05ea\u05d9\u05e7\u05e0\u05d4 \u05dc\u05d9 \u05d0\u05ea \u05d4\u05e0\u05d8\u05d9\u05d9\u05d4 \u05d1\u05d0\u05de\u05e6\u05e2 \u05de\u05e9\u05e4\u05d8 \u05d5\u05dc\u05d0 \u05d4\u05e8\u05d2\u05e9\u05ea\u05d9 \u05e9\u05e4\u05d5\u05d8\u05d9\u05dd. \u05de\u05e9\u05e0\u05d4 \u05db\u05dc\u05dc\u05d9\u05dd.",
  "social.author2": "James R.",
  "social.role2": "\u05dc\u05d5\u05de\u05d3 \u05d2\u05e8\u05de\u05e0\u05d9\u05ea",
  "social.quote3": "\u05e1\u05d5\u05e3 \u05e1\u05d5\u05e3 \u05de\u05e9\u05d4\u05d5 \u05de\u05e2\u05d1\u05e8 \u05dc\u05db\u05e8\u05d8\u05d9\u05e1\u05d9\u05d5\u05ea. \u05e0\u05d9\u05ea\u05d5\u05d7 \u05d4\u05e9\u05d2\u05d9\u05d0\u05d5\u05ea \u05d0\u05d7\u05e8\u05d9 \u05db\u05dc \u05e9\u05d9\u05d7\u05d4 \u05de\u05e8\u05d0\u05d4 \u05dc\u05d9 \u05d1\u05d3\u05d9\u05d5\u05e7 \u05de\u05d4 \u05dc\u05e9\u05e4\u05e8.",
  "social.author3": "Anna L.",
  "social.role3": "\u05dc\u05d5\u05de\u05d3\u05ea \u05e6\u05e8\u05e4\u05ea\u05d9\u05ea",
  "cta.title": "\u05de\u05d5\u05db\u05e0\u05d9\u05dd \u05dc\u05d4\u05ea\u05d7\u05d9\u05dc \u05dc\u05d3\u05d1\u05e8?",
  "cta.subtitle": "\u05d4\u05e6\u05d8\u05e8\u05e4\u05d5 \u05dc\u05dc\u05d5\u05de\u05d3\u05d9\u05dd \u05e9\u05de\u05ea\u05e8\u05d2\u05dc\u05d9\u05dd \u05e9\u05d9\u05d7\u05d5\u05ea \u05d0\u05de\u05d9\u05ea\u05d9\u05d5\u05ea \u05db\u05dc \u05d9\u05d5\u05dd. \u05d7\u05d9\u05e0\u05dd \u05dc\u05d4\u05ea\u05d7\u05dc\u05d4, \u05dc\u05dc\u05d0 \u05db\u05e8\u05d8\u05d9\u05e1 \u05d0\u05e9\u05e8\u05d0\u05d9.",
