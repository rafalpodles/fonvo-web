  "pricing.premium.cta": "\u092e\u0941\u092b\u094d\u0924 \u091f\u094d\u0930\u093e\u092f\u0932 \u0936\u0941\u0930\u0942 \u0915\u0930\u0947\u0902",
  "social.quote1": "\u092e\u0948\u0902\u0928\u0947 Duolingo, Babbel \u0914\u0930 \u0926\u0942\u0938\u0930\u0947 \u0906\u091c\u092e\u093e\u090f &mdash; Fonvo \u092a\u0939\u0932\u0940 \u0910\u092a \u0939\u0948 \u091c\u0939\u093e\u0901 \u092e\u0948\u0902 \u0938\u091a\u092e\u0941\u091a \u092c\u094b\u0932\u0924\u093e \u0939\u0942\u0901\u0964 2 \u0939\u092b\u094d\u0924\u0947 \u092c\u093e\u0926 \u092e\u0948\u0902\u0928\u0947 \u0938\u094d\u092a\u0947\u0928\u093f\u0936 \u092e\u0947\u0902 \u0905\u0938\u0932\u0940 \u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u0940\u0964",
  "social.author1": "Marta K.",
  "social.role1": "\u0938\u094d\u092a\u0947\u0928\u093f\u0936 \u0938\u0940\u0916 \u0930\u0939\u0940 \u0939\u0948\u0902",
  "social.quote2": "\u091f\u094d\u092f\u0942\u091f\u0930 \u0939\u0948\u0930\u093e\u0928\u0940\u091c\u0928\u0915 \u0930\u0942\u092a \u0938\u0947 \u0905\u0938\u0932\u0940 \u0932\u0917\u0924\u0947 \u0939\u0948\u0902\u0964 Luna \u0928\u0947 \u092c\u0940\u091a \u0935\u093e\u0915\u094d\u092f \u092e\u0947\u0902 \u092e\u0947\u0930\u0940 \u0917\u0932\u0924\u0940 \u0938\u0941\u0927\u093e\u0930\u0940 \u0914\u0930 \u092e\u0941\u091d\u0947 \u092c\u0941\u0930\u093e \u092d\u0940 \u0928\u0939\u0940\u0902 \u0932\u0917\u093e\u0964 \u0917\u0947\u092e \u091a\u0947\u0902\u091c\u0930\u0964",
  "social.author2": "James R.",
  "social.role2": "\u091c\u0930\u094d\u092e\u0928 \u0938\u0940\u0916 \u0930\u0939\u0947 \u0939\u0948\u0902",
  "social.quote3": "\u0906\u0916\u093f\u0930\u0915\u093e\u0930 \u092b\u094d\u0932\u0948\u0936\u0915\u093e\u0930\u094d\u0921 \u0938\u0947 \u0906\u0917\u0947 \u0915\u0941\u091b\u0964 \u0939\u0930 \u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u0947 \u092c\u093e\u0926 \u0917\u0932\u0924\u0940 \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u092e\u0941\u091d\u0947 \u092c\u0924\u093e\u0924\u093e \u0939\u0948 \u0915\u093f \u0915\u094d\u092f\u093e \u0938\u0941\u0927\u093e\u0930\u0928\u093e \u0939\u0948\u0964",
  "social.author3": "Anna L.",
  "social.role3": "\u092b\u094d\u0930\u0947\u0902\u091a \u0938\u0940\u0916 \u0930\u0939\u0940 \u0939\u0948\u0902",
  "cta.title": "\u092c\u094b\u0932\u0928\u093e \u0936\u0941\u0930\u0942 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0924\u0948\u092f\u093e\u0930?",
